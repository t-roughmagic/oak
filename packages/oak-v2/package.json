{
  "name": "@oak/oak-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./platform-effect/react": {
      "types": "./dist/platform-effect/react.d.ts",
      "default": "./dist/platform-effect/react.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react-dom": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@oak/react-effect-provider": "workspace:*",
    "effect": "catalog:",
    "react": "catalog:"
  }
}
